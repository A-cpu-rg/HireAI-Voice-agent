generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  name       String?
  apiKey     String?
  agentId    String?
  candidates Candidate[]
  callLogs   CallLog[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Candidate {
  id              String            @id @default(uuid())
  name            String
  email           String
  phone           String
  role            String
  experience      Int
  status          String            @default("pending") // pending, scheduled, in_progress, completed, shortlisted, rejected
  score           Int?
  callId          String?
  scheduledAt     DateTime?
  completedAt     DateTime?
  resumeUrl       String?
  location        String
  appliedAt       DateTime          @default(now())
  avatarColor     String
  tags            String?           // Stored as JSON string
  
  screeningResult ScreeningResult?
  transcript      TranscriptMessage[]
  callLogs        CallLog[]
  
  // Multitenancy
  user            User              @relation(fields: [userId], references: [id])
  userId          String
  // we do not want email uniqueness to cross tenants, uniqueness can be (email, userId) combo.
  @@unique([email, userId])
}

model ScreeningResult {
  id                  String     @id @default(uuid())
  candidateId         String     @unique
  candidate           Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  
  technicalScore      Int
  communicationScore  Int
  problemSolvingScore Int
  cultureFitScore     Int
  overallScore        Int
  
  strengths           String     // JSON array
  concerns            String     // JSON array
  recommendation      String
  summary             String
  keySkills           String     // JSON array
  availability        String
  salaryExpectation   String
}

model TranscriptMessage {
  id          String     @id @default(uuid())
  candidateId String
  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  role        String     // "agent" | "candidate"
  text        String
  timestamp   String
}

model Job {
  id          String   @id @default(uuid())
  title       String
  department  String
  location    String
  type        String
  openings    Int
  applicants  Int      @default(0)
  screened    Int      @default(0)
  shortlisted Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  description String
  skills      String   // JSON array
  salaryRange String
  
  // A Job should probably belong to a User, but keeping simple for now? 
  // Let's add userId if needed later.
}

model CallLog {
  id            String    @id @default(uuid()) // Bolna Call ID
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateName String
  role          String
  duration      String    @default("0m 0s")
  status        String    @default("in-progress")
  startedAt     DateTime  @default(now())
  score         Int?
  agentId       String
  
  // Multitenancy
  user          User      @relation(fields: [userId], references: [id])
  userId        String
}
