generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String      @id @default(uuid())
  email                      String      @unique
  name                       String?
  passwordHash               String?
  emailVerifiedAt            DateTime?
  verificationTokenHash      String?
  verificationTokenExpiresAt DateTime?
  apiKey                     String?
  agentId                    String?
  candidates                 Candidate[]
  callLogs                   CallLog[]
  jobs                       Job[]
  interviews                 Interview[]
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt

  @@index([verificationTokenHash])
}

model Candidate {
  id             String    @id @default(uuid())
  name           String
  email          String
  phone          String
  role           String
  experience     Int
  callStatus     String    @default("pending") // pending, calling, processing, completed, failed
  decisionStatus String    @default("undecided") // undecided, shortlisted, rejected
  score          Int?
  matchScore     Int?
  callId         String?
  scheduledAt    DateTime?
  completedAt    DateTime?
  resumeUrl      String?
  location       String
  appliedAt      DateTime  @default(now())
  avatarColor    String
  tags           String? // Stored as JSON string
  isDemo         Boolean   @default(false)
  jobId          String?

  // Resume-parsing intelligence (see ResumeAnalysis) surfaced for quick access.
  matchConfidence Int? // 0-100 extraction confidence

  // Lightweight fraud signals (see fraud-detection service).
  fraudScore     Int? // 0-100, higher = more suspicious
  fraudFlags     String? // JSON array of flag codes
  fraudCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  screeningResult ScreeningResult?
  resumeAnalysis  ResumeAnalysis?
  transcript      TranscriptMessage[]
  callLogs        CallLog[]
  interviews      Interview[]
  job             Job?                @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Multitenancy
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // we do not want email uniqueness to cross tenants, uniqueness can be (email, userId) combo.
  @@unique([email, userId])
  @@index([userId])
  @@index([jobId])
  @@index([callStatus])
  @@index([decisionStatus])
}

model ResumeAnalysis {
  id          String    @id @default(uuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  matchScore  Int // 0-100 deterministic skill match vs job
  confidence  Int // 0-100 extraction confidence
  skills      String // JSON array
  strengths   String // JSON array
  weaknesses  String // JSON array
  summary     String
  source      String  @default("heuristic") // "ai" | "heuristic"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model ScreeningResult {
  id          String    @id @default(uuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  technicalScore      Int
  communicationScore  Int
  problemSolvingScore Int
  cultureFitScore     Int
  overallScore        Int

  strengths         String // JSON array
  concerns          String // JSON array
  recommendation    String
  summary           String
  keySkills         String // JSON array
  availability      String
  salaryExpectation String
}

model TranscriptMessage {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  role        String // "agent" | "candidate"
  text        String
  timestamp   String

  @@index([candidateId])
}

model Job {
  id          String      @id @default(uuid())
  title       String
  department  String
  location    String
  type        String
  openings    Int
  applicants  Int         @default(0)
  screened    Int         @default(0)
  shortlisted Int         @default(0)
  status      String      @default("active")
  createdAt   DateTime    @default(now())
  description String
  skills      String // JSON array
  salaryRange String
  smartPrompt String?
  candidates  Candidate[]

  // Multitenancy
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
  @@index([status])
}

model CallLog {
  id            String    @id @default(uuid()) // Bolna Call ID
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateName String
  role          String
  duration      String    @default("0m 0s")
  status        String    @default("calling") // pending, calling, processing, completed, failed
  startedAt     DateTime  @default(now())
  score         Int?
  agentId       String

  // Multitenancy
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
  @@index([candidateId])
  @@index([status])
}

enum InterviewStatus {
  proposed
  scheduled
  completed
  cancelled
}

enum InterviewMode {
  phone
  video
  onsite
}

model Interview {
  id          String          @id @default(uuid())
  candidateId String
  candidate   Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  durationMins Int            @default(30)
  mode        InterviewMode   @default(video)
  status      InterviewStatus @default(scheduled)
  interviewer String?
  location    String? // meeting link or address
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  @@index([userId])
  @@index([candidateId])
  @@index([scheduledAt])
  @@index([status])
}
