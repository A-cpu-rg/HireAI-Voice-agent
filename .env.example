# ---------------------------------------------------------------------------
# HireAI Platform — environment configuration
# Copy to `.env` and fill in real values. Validated at boot by src/env.ts.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Secret used to sign session cookies (required, min 16 chars).
# Generate one with:  openssl rand -hex 48
AUTH_SECRET="replace-this-with-a-long-random-secret"

# Public base URL, used to build links in verification emails.
APP_URL="http://localhost:3000"

# Transactional email via Resend (optional in dev — links are logged instead).
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="HireAI <hello@yourdomain.com>"

# Google Gemini API key for resume/JD parsing (optional — falls back to
# heuristic extraction when unset).
GOOGLE_AI_API_KEY="your_gemini_api_key"

# Shared secret Bolna signs inbound webhooks with. When set, webhooks without a
# valid signature are rejected. Strongly recommended in production.
BOLNA_WEBHOOK_SECRET="generate-a-random-secret-and-configure-it-in-bolna"

# NOTE: per-tenant Bolna API key + agent id are NOT set here. Each recruiter
# configures their own in Settings; they are stored per-user in the database.
